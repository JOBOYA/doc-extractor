{
  "name": "doc-extractor",
  "version": "0.1.2",
  "description": "Doc extraction UI + Claude Code integration — crawl any docs site and query it with Claude",
  "bin": {
    "doc-extractor": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "installer/",
    "mcp/",
    "app/",
    "components/",
    "lib/",
    ".next/standalone/",
    ".next/static/",
    "scripts/",
    "next.config.mjs",
    "tailwind.config.ts",
    "tsconfig.json",
    "postcss.config.mjs"
  ],
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "mcp": "node mcp/server.js",
    "postbuild": "node scripts/postbuild.js",
    "prepublishOnly": "cross-env NODE_ENV=production next build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "geist": "^1.3.1",
    "lucide-react": "^0.453.0",
    "next": "^14.2.35",
    "p-queue": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.5",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "documentation",
    "crawler"
  ],
  "author": "Joseph Boyadjian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JOBOYA/doc-extractor.git"
  },
  "bugs": {
    "url": "https://github.com/JOBOYA/doc-extractor/issues"
  },
  "homepage": "https://github.com/JOBOYA/doc-extractor#readme"
}
